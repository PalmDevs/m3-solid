{
	"name": "m3-solid",
	"version": "0.1.0",
	"description": "Material Design 3 components for SolidJS",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./styles.css": {
			"default": "./dist/styles.css"
		},
		"./themes/*.css": {
			"default": "./src/themes/*.css"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite --open",
		"build": "vite build && tsc --emitDeclarationOnly --outDir dist",
		"preview": "vite preview"
	},
	"dependencies": {
		"@iconify-icons/mdi": "^1.2.48",
		"@solid-primitives/refs": "^1.1.3",
		"solid-js": "^1.9.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@iconify/types": "^2.0.0",
		"@types/bun": "1.3.12",
		"typescript": "^6.0.2",
		"vite": "^7.3.2",
		"vite-plugin-dts": "^4.5.4",
		"vite-plugin-solid": "^2.11.12"
	},
	"peerDependencies": {
		"solid-js": "^1.9.12"
	}
}
