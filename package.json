{
	"name": "m3-solid",
	"version": "0.1.0",
	"description": "Material Design 3 components for SolidJS",
	"type": "module",
	"exports": {
		"./src": {
			"import": "./src/index.tsx",
			"types": "./src/index.tsx"
		},
		"./src/*": {
			"import": "./src/*",
			"types": "./src/*"
		},
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./styles.css": {
			"default": "./dist/styles.css"
		},
		"./themes/*.css": {
			"default": "./dist/themes/*.css"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"dev": "vite --open",
		"build": "vite build && tsc --emitDeclarationOnly --outDir dist",
		"preview": "vite preview"
	},
	"dependencies": {
		"@iconify-icons/mdi": "^1.2.48",
		"@solid-primitives/refs": "^1.1.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@iconify/types": "^2.0.0",
		"@types/bun": "1.3.13",
		"typescript": "^6.0.3",
		"vite": "^8.0.12",
		"vite-plugin-dts": "^5.0.0",
		"vite-plugin-solid": "^2.11.12",
		"vite-plugin-static-copy": "^4.1.0"
	},
	"peerDependencies": {
		"solid-js": "^1.9.12"
	}
}